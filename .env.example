# =============================================================================
# Diyanara — Production Environment Variables
# =============================================================================
# Copy this file to .env in the app directory before deploying:
#   cp .env.example .env
#
# Deploy path on VPS: /opt/projects/diyanara/app/
# Persistent data:   /opt/projects/diyanara/data/
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_USER=diyanara
POSTGRES_PASSWORD=change-me-use-a-strong-password
POSTGRES_DB=diyanara

# Path to persistent data directory (relative to docker-compose.yml location)
# On VPS this resolves to /opt/projects/diyanara/data/
DATA_PATH=../data

# ---- Application URLs ----
# Public URLs as seen by browsers and external services (Stripe, PostNord)
FRONTEND_URL=https://diyanara.example.com
BACKEND_URL=https://diyanara.example.com

# Comma-separated list of allowed CORS origins
CORS_ORIGIN=https://diyanara.example.com

# Frontend build: leave empty when using Docker (nginx proxies API internally)
VITE_API_URL=

# ---- Security ----
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-use-openssl-rand-base64-48
JWT_EXPIRES_IN=7d

# Proxy hops: Cloudflare (1) + host Nginx (2). Adjust if your stack differs.
TRUST_PROXY_HOPS=2

# ---- Stripe ----
# Test mode:  sk_test_...  /  whsec_...  (from Stripe Dashboard → Developers)
# Live mode:  sk_live_...  /  whsec_...  (switch keys only — no code changes)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Set to true only on staging to allow mock checkout without real Stripe keys
ALLOW_MOCK_PAYMENTS=false

# ---- PostNord ----
# Leave as postnord_xxx for mock labels during development
POSTNORD_API_KEY=postnord_xxx
POSTNORD_API_URL=https://api2.postnord.com/rest/shipment/v5/shipment
POSTNORD_SERVICE_CODE=17

# Sender address printed on shipping labels
SENDER_NAME=Diyanara
SENDER_ADDRESS=Storegade 1
SENDER_ZIP=1000
SENDER_CITY=København
SENDER_COUNTRY=DK
SENDER_EMAIL=shop@diyanara.test
SENDER_PHONE=+4500000000

# ---- Email (prepared for future integration) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Diyanara <noreply@diyanara.example.com>

# ---- Database seed (first deploy only) ----
# Set RUN_SEED=true on first deploy, then set back to false
RUN_SEED=false
ADMIN_EMAIL=admin@diyanara.test
ADMIN_PASSWORD=change-me-before-first-seed

# ---- Container memory limits (protect other projects on shared VPS) ----
# Total default cap: ~1.15 GB. Increase on larger VPS after checking `docker stats`.
POSTGRES_MEMORY_LIMIT=512M
POSTGRES_MEMORY_RESERVATION=256M
BACKEND_MEMORY_LIMIT=512M
BACKEND_MEMORY_RESERVATION=128M
FRONTEND_MEMORY_LIMIT=128M
FRONTEND_MEMORY_RESERVATION=64M

# ---- Optional ----
# NODE_ENV is set to production by docker-compose for backend
# DATA_DIR, LABELS_DIR, UPLOADS_DIR are set automatically in Docker
