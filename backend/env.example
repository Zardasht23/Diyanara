DATABASE_URL="postgresql://diyanara:change-me@localhost:5432/diyanara?schema=public"
JWT_SECRET="change-me-in-prod-this-must-be-a-long-random-string"
JWT_EXPIRES_IN="7d"
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# Public URLs (used for Stripe redirects, CORS, etc.)
FRONTEND_URL="http://localhost:5173"
BACKEND_URL="http://localhost:3001"

# Stripe - use test keys from https://dashboard.stripe.com/test/apikeys
# Leave as "sk_test_xxx" to enable mock-mode checkout (no real Stripe call).
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# PostNord Booking API - requires a PostNord Business contract.
# Leave as "postnord_xxx" to enable mock-mode label PDFs (printable, fake tracking).
POSTNORD_API_KEY="postnord_xxx"
POSTNORD_API_URL="https://api2.postnord.com/rest/shipment/v5/shipment"
POSTNORD_SERVICE_CODE="17"

# Sender info printed on labels
SENDER_NAME="Diyanara"
SENDER_ADDRESS="Storegade 1"
SENDER_ZIP="1000"
SENDER_CITY="København"
SENDER_COUNTRY="DK"
SENDER_EMAIL="shop@diyanara.test"
SENDER_PHONE="+4500000000"

# Email (prepared for future integration — not used yet)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Diyanara <noreply@diyanara.test>"

# Persistent storage paths (Docker sets these automatically)
DATA_DIR="./data"
LABELS_DIR="./data/labels"
UPLOADS_DIR="./data/uploads"

# Proxy hops for reverse proxy stack
TRUST_PROXY_HOPS=1

# Allow mock Stripe checkout without real keys (development/staging only)
ALLOW_MOCK_PAYMENTS=true

# Seed admin (run manually: npm run prisma:seed)
ADMIN_EMAIL="admin@diyanara.test"
ADMIN_PASSWORD="admin123"
